# Supabase — copy this file to .env.local and fill in values from your Supabase project
# Project Settings -> API

# Public project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; RLS protects your data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: where the app lives, used for auth email redirect links.
# In local dev this is http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI — powers the AI sale-entry assistant (Phase 7). Server-side only.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
