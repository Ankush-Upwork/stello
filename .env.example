# Supabase — copy this file to .env.local and fill in values from your Supabase project
# Project Settings -> API

# Public project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to the browser; RLS protects your data)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: where the app lives, used for auth email redirect links.
# In local dev this is http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI — powers the AI features. Server-side only.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Transactional email (Resend) — for upgrade-request notifications. Optional:
# flows still work without it (emails are just skipped). https://resend.com
RESEND_API_KEY=
# Verified sender, e.g. "Sello <noreply@sello.datavoris.com>"
EMAIL_FROM=
# Where new upgrade requests are emailed (your inbox)
ADMIN_EMAIL=
